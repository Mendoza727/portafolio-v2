# ─── Contact Form ────────────────────────────────────────────────────────────
# Get your endpoint at https://formspree.io
NEXT_PUBLIC_FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID

# ─── Google reCAPTCHA v2 ─────────────────────────────────────────────────────
# Register at https://www.google.com/recaptcha/admin — choose "Challenge v2"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key

# ─── GitHub ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
NEXT_PUBLIC_GITHUB_CONTRIBUTIONS_API=https://github-contributions-api.jogruber.de/v4

# ─── Personal Info ────────────────────────────────────────────────────────────
NEXT_PUBLIC_OWNER_NAME=Your Full Name
NEXT_PUBLIC_OWNER_EMAIL=your@email.com
NEXT_PUBLIC_OWNER_PHONE=(000) 000-0000
NEXT_PUBLIC_OWNER_PHONE_E164=+000000000000
NEXT_PUBLIC_OWNER_LOCATION=Your City, Country

# ─── Social Links ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/your_username
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/in/your_profile/
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/your_handle
